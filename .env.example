# WORKKK 环境变量说明
# 全部可选，不设置也能正常运行（明信片功能使用本地随机文案兜底）

# ── 明信片 AI 生成（三选一） ──────────────────────────────────────────────────
# 方案 A：Anthropic API（使用 claude-haiku 生成）
# ANTHROPIC_API_KEY=sk-ant-...

# 方案 B：OpenAI API
# OPENAI_API_KEY=sk-...

# 方案 C：兼容 OpenAI 格式的第三方 API（DeepSeek / Groq / Together / Ollama 等）
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ── Railway 部署（自动注入，无需手动设置） ────────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
